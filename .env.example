# Production Environment Configuration
# No Code Architect Toolkit

# The name of your application.
APP_NAME=NCAToolkit

# Debug mode setting. Set to `false` for production environments.
APP_DEBUG=false

# Your app's domain or subdomain, without the 'http://' or 'https://' prefix.
APP_DOMAIN=example.com

# Full application URL is automatically configured; no modification required.
APP_URL=https://${APP_DOMAIN}

# SSL settings
SSL_EMAIL=user@example.com

# API_KEY
# Purpose: Used for API authentication.
# Requirement: Mandatory.
API_KEY=your_api_key_here

# Dashboard Password Protection
# Purpose: Restricts access to the /leads dashboard with a browser login prompt.
# Requirement: Optional. Without these, the dashboard is publicly accessible.
#DASHBOARD_USER=admin
#DASHBOARD_PASSWORD=your_secure_password_here

# s3 Compatible Storage Env Vars
#
#S3_ACCESS_KEY=your_access_key
#S3_SECRET_KEY=your_secret_key
#S3_ENDPOINT_URL=https://your-endpoint-url
#S3_REGION=your-region
#S3_BUCKET_NAME=your-bucket-name


# Google Cloud Storage Env Variables
#
# GCP_SA_CREDENTIALS
# Purpose: The JSON credentials for the GCP Service Account.
# Requirement: Mandatory if using GCP storage.
#GCP_SA_CREDENTIALS=/path/to/your/gcp/service_account.json

# GCP_BUCKET_NAME
# Purpose: The name of the GCP storage bucket.
# Requirement: Mandatory if using GCP storage.
#GCP_BUCKET_NAME=your_gcp_bucket_name

# LOCAL_STORAGE_PATH
# Purpose: The local file system path for temporary file storage during processing.
# Default: /tmp
# Requirement: Optional.
#LOCAL_STORAGE_PATH=/tmp

# Google Cloud Run Jobs
# Purpose: Offload long-running tasks to Cloud Run Jobs for scalability
# Requirement: Optional. Configure if you want to use GCP Cloud Run Jobs.
#
# GCP_JOB_NAME
# Purpose: Name of the Cloud Run Job to trigger for long-running tasks
# Requirement: Required if using Cloud Run Jobs
#GCP_JOB_NAME=your-cloud-run-job-name
#
# GCP_JOB_LOCATION
# Purpose: GCP region where the Cloud Run Job is deployed
# Requirement: Optional. Defaults to us-central1
#GCP_JOB_LOCATION=us-central1

# Google Maps Platform
# Purpose: Used for the /v1/google/places/search route
# Requirement: Required if using Google Maps/Places features
#GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Prospeo.io
# Purpose: Used for the /v1/prospeo/find_email route
# Requirement: Required if using Prospeo email finder features
#PROSPEO_API_KEY=your_prospeo_api_key_here

# Monday.com CRM
# Purpose: Used to export leads to Monday.com
#MONDAY_API_TOKEN=your_monday_api_token_here
#MONDAY_WORKSPACE_ID=your_workspace_id_here

# ReachInbox AI
# Purpose: Used to push leads into cold email campaigns
#REACHINBOX_API_KEY=your_reachinbox_api_key_here

# OpenWebNinja
# Purpose: Used to enrich leads with recent company news
#OPENWEBNINJA_KEY=your_openwebninja_key_here

# OpenRouter
# Purpose: AI-generated company analysis on each lead card (summary, category, cold email angle)
# Uses openai/gpt-4o-mini by default (~$0.003 per 20-lead search)
# Requirement: Optional. Without it, AI Insights section is hidden.
#OPENROUTER_API_KEY=your_openrouter_api_key_here

# MillionVerifier
# Purpose: Validates contact emails after Prospeo/Blitz finding — marks valid/invalid on lead cards
# Requirement: Optional. Without it, emails show unverified.
#MILLIONVERIFIER_API_KEY=your_millionverifier_api_key_here

# Blitz
# Purpose: Domain-first contact discovery (owners/founders/CEOs) with LinkedIn URLs and company phone numbers
# Blitz runs first; Prospeo fills any email gaps. Required for phone coverage on all leads.
# Base URL can be overridden per region with BLITZ_BASE_URL (default: https://api.useblitz.com)
#BLITZ_API_KEY=your_blitz_api_key_here
#BLITZ_BASE_URL=https://api.useblitz.com

# RapidAPI — Local Business Data API
# Purpose: Pulls business-level email addresses for local SMBs (landscapers, contractors, etc.)
# that are not indexed by Prospeo or Blitz. Uses Google place_id for exact matching.
# Subscribe at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/local-business-data
# Requirement: Optional. Without it, business_email field is empty on lead cards.
#RAPIDAPI_KEY=your_rapidapi_key_here